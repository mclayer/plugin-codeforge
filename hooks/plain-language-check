#!/usr/bin/env bash
# codeforge — Stop hook: 직전 답변의 codeforge 내부 jargon 검사 (CFP-1738)
#
# 책임: 직전 답변(이번 turn)에 codeforge 내부 식별자가 임계치 이상이면
#       decision=block 으로 Orchestrator 가 평범하게 다시 쓰게 유도.
# 회피 대상 = codeforge 내부 식별자만. 일반 기술 용어는 검사 안 함.
#
# 구현: transcript JSONL 파싱은 python 으로 (bash 보다 견고). python 없으면 통과(fail-safe).
# bypass: BYPASS_PLAIN_LANGUAGE=1 → 검사 생략.
# fail-safe: python 부재 / 오류 시 차단하지 않고 통과.
set -uo pipefail

[ "${BYPASS_PLAIN_LANGUAGE:-0}" = "1" ] && exit 0

DIR="$(cd "$(dirname "$0")" && pwd)"

if command -v python3 >/dev/null 2>&1; then
  PY=python3
elif command -v python >/dev/null 2>&1; then
  PY=python
else
  exit 0   # python 없음 → 검사 생략 (fail-safe, 차단 안 함)
fi

exec "$PY" "$DIR/plain-language-check.py"
