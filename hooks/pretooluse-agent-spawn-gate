#!/usr/bin/env bash
# SPDX-License-Identifier: MIT (file structure adapted from superpowers v5.1.0)
# PreToolUse(Agent) hook for codeforge plugin — spawn-format 4-block gate
#
# Carrier: CFP-1742 (Story-2 of Epic CFP-1740 — ADR-115 §결정 1·4·6)
# 채널 2 부가 (CFP-2567 / ADR-071 §결정 22): 4-block warning(stderr)과 별개로, spawn 직전
#   전환-자율 reminder 를 stdout additionalContext 로 non-block inject (NEVER deny — Wave1 무손상).
#
# 책임 경계 (ADR-115 §결정 1 / §결정 4 / §결정 6 정합):
#   - 책임: Agent tool spawn 직전 spawn-prompt 안 필수 4 block presence 검증.
#           Wave 1 warning-only — 누락 시 stderr warning 발화 + exit 0 (deny 비활성).
#           Wave 2 (별 sub-CFP, ADR-060 evidence-gate 후): stdout JSON deny 활성.
#   - 비책임: spawn prompt 내용 변조 금지. inline-write 검출 영역 외 (Change Plan §결정 6).
#             코드 품질 / 보안 검사 영역 외 (CodeReview / SecurityTest lane 책임).
#
# 검증 대상 4 block (ADR-115 §결정 6 closed-set):
#   1. [PRE-SPAWN-ORIGIN-MAIN-SHA] : <SHA>  — ADR-082 Amendment 15 1-E
#   2. [USER-UTTERANCE-VERBATIM]            — ADR-082 Amendment 5 1-C
#   3. worktree-first directive presence    — ADR-040 Amendment 6
#   4. parallel-dispatch directive presence — ADR-064 Amendment 1
#
# Wave 1 출력 (warning-only):
#   - 4 block 모두 present  → exit 0 (no warning)
#   - 1+ block 누락         → stderr warning per block + exit 0 (deny 비활성)
#   - BYPASS env 설정       → stderr audit + exit 0 (bypass audit trail)
#
# 정적 properties (ADR-115 §결정 5 / ADR-038 §결정 7·8 정합):
#   (a) set -euo pipefail + exit 0 trap — 어떤 fail 도 spawn block 금지 (Wave 1)
#   (b) filesystem touch 0 — no >, >>, mkdir, rm, mv, cp (stdin/stderr 만)
#   (c) network call 0
#   (d) Python 호출 — ADR-061 Amendment 3 외부 .py 파일 (heredoc 금지)
#   (e) timeout 내 exit 0 종료 (PreToolUse 30s 기준, < 500ms 목표 §7.4 OR-1)
#
# Graceful degradation 5층 (ADR-115 §결정 5 closed-set):
#   (a) hook 파일 부재 → harness skip (본 파일 존재 시 N/A)
#   (b) bash interpreter 부재 → run-hook.cmd `exit /b 0` silent fail-open
#   (c) Python 부재 / 오류 → stderr warning + exit 0 (spawn 허용)
#   (d) stdin 읽기 실패 → check_spawn_prompt_format.py 가 빈 텍스트 처리
#   (e) 어떤 fail 도 Wave 1 spawn block 금지
#
# Bypass:
#   BYPASS_CODEFORGE_PRETOOLUSE_AGENT_GATE=1 → stderr audit echo + exit 0
#   (scope disjoint — BYPASS_CROSS_REPO_GH_SAFETY / BYPASS_CODEFORGE_PREREQ 등과 별 env)
#
# one-channel rule (ADR-115 §결정 3):
#   marker: [codeforge-wrapper-pretooluse-agent-gate]
#
# Sibling hook disjoint axis:
#   hooks/cross-repo-gh-safety = PreToolUse(Bash) 담당 (cwd gh write safety)
#   본 hook   = PreToolUse(Agent) 담당 (spawn-format 4-block gate)
#   두 hook 은 서로 다른 matcher 에 등록 — 상호 독립 (ADR-115 §결정 3 정합)

set -euo pipefail

# 어떤 실패도 exit 0 으로 trap — Wave 1 spawn block 금지 (ADR-115 §결정 4·5)
trap 'exit 0' ERR

# ── Bypass check (audit trail 의무) ──────────────────────────────────────────
if [ "${BYPASS_CODEFORGE_PRETOOLUSE_AGENT_GATE:-0}" = "1" ]; then
  >&2 printf '[codeforge-wrapper-pretooluse-agent-gate] BYPASS_CODEFORGE_PRETOOLUSE_AGENT_GATE=1 — spawn-format gate suppressed at %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  exit 0
fi

# ── stdin = PreToolUse JSON payload 읽기 ─────────────────────────────────────
PAYLOAD="$(cat 2>/dev/null || true)"

# payload 가 비어있으면 pass-through (scope 외)
if [ -z "$PAYLOAD" ]; then
  exit 0
fi

# NOTE (CFP-2587 Phase 2): 구 채널 2 standalone reminder 호출 블록은 제거됨.
#   전환-자율 reminder(additionalContext)는 이제 하단 description INJECTION 블록의 단일
#   `--inject --transition-reminder` 호출로 MERGE 됨 (updatedInput + additionalContext = 단일 stdout JSON).
#   → hook stdout = 정확히 하나의 JSON (구 reminder emit + 구 detect 통합).

# ── 공용 resolve: PLUGIN_ROOT + Python 인터프리터 (verifier + prompt 추출 + inject 공용) ──
#   ★ CFP-2587 FIX-2 F1: PLUGIN_ROOT / PYTHON_CMD 를 prompt early-exit 상류로 hoist —
#   빈/부재 prompt 시에도 하단 injection/reminder 블록이 이 변수를 사용 가능하게 함 (§7.3 회복).
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-}"
PYTHON_CMD=""
if command -v python3 >/dev/null 2>&1; then
  PYTHON_CMD="python3"
elif command -v python >/dev/null 2>&1; then
  PYTHON_CMD="python"
fi

# ── spawn prompt 추출 (jq 비의존 — Python stdlib json) ────────────────────────
#   추출 실패 시 fail-open (false-negative 가 false-positive 보다 안전 — Wave 1).
PROMPT_TEXT=""
if [ -n "$PYTHON_CMD" ]; then
  PROMPT_TEXT="$(printf '%s' "$PAYLOAD" | "$PYTHON_CMD" -c "
import json, sys
try:
    data = json.load(sys.stdin)
    tool_input = data.get('tool_input', {})
    prompt = tool_input.get('prompt', '') if isinstance(tool_input, dict) else ''
    print(prompt, end='')
except Exception:
    pass
" 2>/dev/null || true)"
fi

# ── 4-block presence 검증 (PROMPT_TEXT 존재 시에만) ───────────────────────────
#   ★ CFP-2587 FIX-2 F1: 구 회귀 = 빈 PROMPT_TEXT 시 여기서 `exit 0` early-exit 가 하단 merged
#   `--inject --transition-reminder`(§7.3 LOAD-BEARING: additionalContext UNCONDITIONAL emit)를
#   unreachable 화 → story-transition-autonomy reminder 소실. exit 대신 4-block verifier 만 skip
#   하고 injection/reminder 블록으로 fall-through — reminder 무조건 emit 회복. fail-open 유지.
if [ -z "$PROMPT_TEXT" ]; then
  >&2 printf '[codeforge-wrapper-pretooluse-agent-gate] WARN: spawn prompt extraction failed or empty (Python unavailable / JSON parse error / prompt 부재) — 4-block warning skipped, spawn allowed (Wave 1 graceful degradation)\n'
else
  # ── Python verifier 호출 (ADR-061 Amendment 3 정합) ──
  # scripts/lib/check_spawn_prompt_format.py 가 4 block presence 검증.
  VERIFIER_SCRIPT=""
  if [ -n "$PLUGIN_ROOT" ] && [ -f "${PLUGIN_ROOT}/scripts/lib/check_spawn_prompt_format.py" ]; then
    VERIFIER_SCRIPT="${PLUGIN_ROOT}/scripts/lib/check_spawn_prompt_format.py"
  elif [ -f "scripts/lib/check_spawn_prompt_format.py" ]; then
    VERIFIER_SCRIPT="scripts/lib/check_spawn_prompt_format.py"
  fi

  if [ -z "$VERIFIER_SCRIPT" ]; then
    >&2 printf '[codeforge-wrapper-pretooluse-agent-gate] WARN: check_spawn_prompt_format.py not found — spawn allowed (Wave 1 graceful degradation)\n'
  elif [ -n "$PYTHON_CMD" ]; then
    # verifier 실행 — exit 1 = missing blocks, exit 0 = all present
    VERIFIER_OUT=""
    VERIFIER_EXIT=0
    VERIFIER_OUT="$(printf '%s' "$PROMPT_TEXT" | "$PYTHON_CMD" "$VERIFIER_SCRIPT" --prompt-stdin 2>/dev/null)" || VERIFIER_EXIT=$?

    # Wave 1: exit code 에 무관하게 exit 0 (warning-only). 누락 block 목록 파싱 후 stderr warning.
    if [ "$VERIFIER_EXIT" -ne 0 ]; then
      MISSING_BLOCKS=""
      if [ -n "$VERIFIER_OUT" ]; then
        MISSING_BLOCKS="$(printf '%s' "$VERIFIER_OUT" | "$PYTHON_CMD" -c "
import json, sys
try:
    data = json.loads(sys.stdin.read())
    missing = data.get('missing', [])
    print(', '.join(missing))
except Exception:
    pass
" 2>/dev/null || true)"
      fi

      if [ -n "$MISSING_BLOCKS" ]; then
        >&2 printf '[codeforge-wrapper-pretooluse-agent-gate] WARN: spawn prompt missing required blocks: [%s]\n' "$MISSING_BLOCKS"
        >&2 printf '  ADR-115 §결정 6 / Change Plan §3.3 — 4 block presence 의무:\n'
        >&2 printf '  1. [PRE-SPAWN-ORIGIN-MAIN-SHA] : <SHA>  (ADR-082 Amendment 15 1-E)\n'
        >&2 printf '  2. [USER-UTTERANCE-VERBATIM]            (ADR-082 Amendment 5 1-C)\n'
        >&2 printf '  3. worktree-first directive             (ADR-040 Amendment 6)\n'
        >&2 printf '  4. parallel-dispatch directive          (ADR-064 Amendment 1)\n'
        >&2 printf '  Wave 1: warning-only (spawn allowed). Wave 2 deny 활성 = 별 sub-CFP carrier.\n'
        >&2 printf '  Bypass: BYPASS_CODEFORGE_PRETOOLUSE_AGENT_GATE=1\n'
      else
        >&2 printf '[codeforge-wrapper-pretooluse-agent-gate] WARN: spawn prompt format issue detected — spawn allowed (Wave 1)\n'
      fi
    fi
  fi
fi

# ── 범위① description INJECTION + 전환-자율 reminder MERGE (CFP-2587 Phase 2) ──
# tool_input.description 에 렌더-줄 프리픽스 `[<subagent_type>] MM/DD HH:MM - <내용>` 를
# hookSpecificOutput.updatedInput 으로 주입(mechanical) + 전환-자율 reminder additionalContext 를
# 동일 JSON 에 병합 → hook stdout = 정확히 하나의 JSON. ★ F1 이후 본 블록은 PROMPT_TEXT 유무와
# 무관하게 UNCONDITIONAL 도달 (§7.3 LOAD-BEARING).
#
# 계약 (Change Plan §7.2/§7.3 · spike verdict):
#   · whole-echo REPLACE-safe · bare updatedInput (permissionDecision 미emit, G4) · fail-open (G5).
#   · #15897 caveat (ADR-119): worst-case = clean prefix loss = advisory ceiling, never wrong-value.

# subagent_type 추출 + FIELD presence 판정 (spike AC-7 / §7.7-2).
#   ★ F3 (CFP-2587 FIX-2): subagent_type FIELD 부재(키 자체 없음) → injection SKIP (reminder 는 유지) —
#   Bash 표면 shell EXCLUDE 와 대칭. FIELD present-but-empty → build_injected_description 의 G2
#   unknown-agent fallback. presence + value 를 1-fork 로 판정(perf; P: 접두=present, A:=absent).
SUBAGENT_TYPE=""
SUBAGENT_TYPE_ABSENT="1"
if [ -n "$PYTHON_CMD" ]; then
  _ST="$(printf '%s' "$PAYLOAD" | "$PYTHON_CMD" -c "
import json, sys
try:
    ti = json.load(sys.stdin).get('tool_input', {})
    if isinstance(ti, dict) and 'subagent_type' in ti:
        v = ti.get('subagent_type')
        sys.stdout.write('P:' + (v if isinstance(v, str) else ''))
    else:
        sys.stdout.write('A:')
except Exception:
    sys.stdout.write('A:')
" 2>/dev/null || true)"
  case "$_ST" in
    P:*) SUBAGENT_TYPE_ABSENT="0"; SUBAGENT_TYPE="${_ST#P:}" ;;
    *)   SUBAGENT_TYPE_ABSENT="1"; SUBAGENT_TYPE="" ;;
  esac
fi

# KST render stamp (fallback empty — kst-render-stamp.sh 실패 시 build_injected_description 이 skip)
STAMP=""
if [ -n "$PLUGIN_ROOT" ] && [ -f "${PLUGIN_ROOT}/scripts/kst-render-stamp.sh" ]; then
  STAMP="$(bash "${PLUGIN_ROOT}/scripts/kst-render-stamp.sh" 2>/dev/null || true)"
elif [ -f "scripts/kst-render-stamp.sh" ]; then
  STAMP="$(bash "scripts/kst-render-stamp.sh" 2>/dev/null || true)"
fi

# check_spawn_description_prefix.py resolve (PLUGIN_ROOT path with cwd fallback)
DESC_CHECKER=""
if [ -n "$PLUGIN_ROOT" ] && [ -f "${PLUGIN_ROOT}/scripts/lib/check_spawn_description_prefix.py" ]; then
  DESC_CHECKER="${PLUGIN_ROOT}/scripts/lib/check_spawn_description_prefix.py"
elif [ -f "scripts/lib/check_spawn_description_prefix.py" ]; then
  DESC_CHECKER="scripts/lib/check_spawn_description_prefix.py"
fi

# SINGLE call — updatedInput + additionalContext 병합 JSON.
#   ★ F3: subagent_type FIELD 부재 → --subject-absent (injection skip, reminder 유지).
#   ★ F5: --bypass-env = Agent 표면 전용 env (Bash 표면 env 와 disjoint — cross-surface bleed 방지).
if [ -n "$DESC_CHECKER" ] && [ -n "$PYTHON_CMD" ]; then
  if [ "$SUBAGENT_TYPE_ABSENT" = "1" ]; then
    printf '%s' "$PAYLOAD" | "$PYTHON_CMD" "$DESC_CHECKER" --inject --subject "$SUBAGENT_TYPE" --kst-stamp "$STAMP" --transition-reminder --bypass-env BYPASS_CODEFORGE_PRETOOLUSE_AGENT_GATE --subject-absent 2>/dev/null || true
  else
    printf '%s' "$PAYLOAD" | "$PYTHON_CMD" "$DESC_CHECKER" --inject --subject "$SUBAGENT_TYPE" --kst-stamp "$STAMP" --transition-reminder --bypass-env BYPASS_CODEFORGE_PRETOOLUSE_AGENT_GATE 2>/dev/null || true
  fi
fi

# Wave 1: 항상 exit 0 (deny 비활성)
exit 0
