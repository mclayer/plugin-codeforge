#!/usr/bin/env bash
# pre-push.sh.example — Consumer-side pre-push hook template (CFP-132 / Issue #236).
#
# 매 phase production push 전 lint 자동 실행 — CI ruff/pyright fail → fix → push
# iter 4-round 평균 ($ 비용 폭증) friction 회피.
#
# Install (수동 cp):
#   cp ${CLAUDE_PLUGIN_ROOT}/codeforge/overlay/hooks/pre-push.sh.example .git/hooks/pre-push
#   chmod +x .git/hooks/pre-push
#
# 또는 (core.hooksPath 사용):
#   mkdir -p .githooks
#   cp ${CLAUDE_PLUGIN_ROOT}/codeforge/overlay/hooks/pre-push.sh.example .githooks/pre-push
#   chmod +x .githooks/pre-push
#   git config core.hooksPath .githooks
#
# Bypass (긴급 push, lint 우회):
#   git push --no-verify
#
# Rollback:
#   rm .git/hooks/pre-push    # (또는 git config --unset core.hooksPath)

set -u

# scripts/check-lint.sh 호출 — consumer-scripts.manifest 통해 다운로드된 standard wrapper
if [ -f "scripts/check-lint.sh" ]; then
    bash scripts/check-lint.sh
    exit $?
fi

# Fallback: scripts/check-lint.sh 부재 시 silent skip (consumer 가 manifest 미적용 환경)
echo "[pre-push] scripts/check-lint.sh 부재 — lint skip. consumer-scripts.manifest 적용 권장." >&2
exit 0
