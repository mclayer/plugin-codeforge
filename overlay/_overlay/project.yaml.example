# .claude/_overlay/project.yaml — consumer SSOT 상수
#
# Schema 전체 명세: ../../docs/project-config-schema.md
# 각 <REPLACE> 값을 본 프로젝트 값으로 치환해 사용.

project:
  name: "<REPLACE — e.g. task-manager>"
  repo: "<REPLACE — e.g. github.com/acme/task-manager>"

atlassian:
  site: "<REPLACE — e.g. acme.atlassian.net>"

  confluence:
    space_key: "<REPLACE — e.g. TM>"
    stories_parent_page_id: "<REPLACE — Story 페이지들의 parent pageId (int 또는 string)>"
    domain_knowledge_parent_page_id: "<REPLACE — Domain Knowledge 루트 pageId>"
    adr_root_page_id: "<REPLACE — ADR 루트 pageId>"

  jira:
    project_key: "<REPLACE — e.g. TM>"
    # transitions 섹션은 선택. 없으면 DocsAgent가 런타임에
    # getTransitionsForJiraIssue로 동적 획득. 고정 매핑이
    # 필요하거나 transition 이름이 비표준이면 아래 주석 해제.
    #
    # transitions:
    #   to_in_progress: 21
    #   to_done: 31

github:
  pr_title_prefix_template: "[{project_key}-{story_number}] {title}"

labels:
  components:
    - "<REPLACE — 프로젝트 component 1 (e.g. api)>"
    - "<REPLACE — 프로젝트 component 2 (e.g. ui)>"
    - "<REPLACE — 프로젝트 component 3 (e.g. data)>"
