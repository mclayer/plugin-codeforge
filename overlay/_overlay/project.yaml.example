# .claude/_overlay/project.yaml — consumer SSOT 상수
#
# Schema 전체 명세: ../../docs/project-config-schema.md
# 각 <REPLACE> 값을 본 프로젝트 값으로 치환해 사용.

project:
  name: "<REPLACE — e.g. task-manager>"

github:
  org: "<REPLACE — GitHub org 또는 user, e.g. acme>"
  repo: "<REPLACE — repo 이름, e.g. task-manager>"
  default_branch: main

  # PR 제목 prefix 템플릿. {key}·{title} placeholder 지원.
  pr_title_prefix_template: "[{key}] {title}"

  # Issue 번호 prefix. e.g. "TM" → "TM-7"
  story_key_prefix: "<REPLACE — e.g. TM>"

  codeowners:
    architect_team: "<REPLACE — e.g. @acme/architects>"
    domain_expert_team: "<REPLACE — e.g. @acme/domain-experts>"

  discussions:
    domain_kb_category: "Domain Q&A"

  milestone:
    epic_naming_pattern: "Epic-{key}-{slug}"

labels:
  components:
    - "<REPLACE — 프로젝트 component 1 (e.g. api)>"
    - "<REPLACE — 프로젝트 component 2 (e.g. ui)>"
    - "<REPLACE — 프로젝트 component 3 (e.g. data)>"

# Phase gate hub repo 화이트리스트 확장 (CFP-1716 / ADR-116)
# Consumer hub repo 가 default 외 다른 경우 여기 추가.
# Mechanism: bash scripts/inject-allowed-hub-repos.sh 실행 (idempotent, dedup, never-reduce)
# 정책: ADR-116 확장-only — 축소 금지 (선례 ADR-026 Amd4 §결정 6 / ADR-024 §결정 6)
# 비활성 시 이 블록 전체 삭제 또는 주석 유지.
# phase_gate:
#   allowed_hub_repos:
#     - "github.com/mclayer/mctrader-hub"  # Consumer hub repo (추가)

# Workflow distribution mode (CFP-86 / consumer-guide §2c, CFP-89)
# - "full" (Path A, default) = 7 workflow 모두 보유 (CFP-94 후 — story-section-schema.yml 추가)
# - "degraded" (Path B) = 일부 workflow 부재, manual compensating check 의무
workflow_distribution:
  mode: full
  missing_workflows: []
  # mctrader-hub Path B 예시:
  # mode: degraded
  # missing_workflows:
  #   - story-init.yml
  #   - story-section-1-immutable.yml
  #   - fix-ledger-sync.yml
  #   - subissue-from-impl-manifest.yml

# Progress narration verbosity (CFP-114 / ADR-029)
# - "full" (default) = 모든 sub-step event narrate (Deputy spawn/return / 병렬 dispatch / R9 subset 등)
# - "lane_only" = lane-level event 만 narrate (CFP-20 기존 동작)
progress_narration_verbosity: full

# Bootstrap protocol settings (CFP-103, ADR-027) — optional section, all commented
# bootstrap:
#   # Override expected workflow set. Default = check_bootstrap.EXPECTED_WORKFLOWS_FULL.
#   # Path B (degraded) consumer 가 모든 workflow 가질 필요 없을 때 명시.
#   expected_workflows:
#     - phase-gate-mergeable.yml
#     - phase-label-invariant.yml
#
#   # CFP-127 / ADR-032 amendment 1 — strict mode opt-in (priority 3, CLI > env > yaml).
#   # true 시: strict-eligible drift 4종 (project.yaml 부재 / plugin 8 critical 미설치 /
#   # settings.json 3 hook 미등록 / phase:* + gate:* 10 critical label 부재) 발견 → exit 1.
#   # 점진 도입 권장 — mctrader 6-repo first opt-in target.
#   # Revert: false 또는 field 삭제 + commit.
#   # ADR-027 §결정 3 Bypass (HOTFIX_BYPASS_CODEFORGE=1 + REASON) 와 별도 mechanism (Bypass priority HIGHEST).
#   strict_mode: false
#
#   # CFP-658 Phase 2 / ADR-027 Amendment 2 §결정 6.A — Action 차단 환경 fallback mode (optional, default: auto)
#   # Trigger (A) declarative: enterprise GitHub Actions default_workflow_permissions:read 차단 환경
#   # Trigger (C): Issue 발의자 ad-hoc override 시 `fallback:manual` label 부착 (우선순위 (C) > (A))
#   # 우선순위: CLI > env > yaml (ADR-032 일관성)
#   #   "auto" (default): GitHub Actions story-init.yml 정상 동작 환경 — 수동 개입 없음
#   #   "action_blocked": GitHub Actions 차단 확인된 환경 — agent direct write fallback path 활성화
#   #                     → Orchestrator §3.15 fallback decision tree 발동
#   #                     → manual-story-init-fallback.sh (또는 .ps1) 사용
#   # fallback_mode: action_blocked  # (optional, default: auto) — ADR-027 Amendment 2 §결정 6.A
#
# bypass env vars (ADR-027 결정 3, CFP-104 후행) — informational only
# 실제 bypass 는 hook 안에서 env 검사:
# HOTFIX_BYPASS_CODEFORGE=1 + HOTFIX_BYPASS_REASON="<text>" 동시 설정 의무

# Multi-repo story key system (CFP-342 / ADR-050) — 선택, 기본 비활성
# single-repo consumer 는 이 블록 전체를 삭제하거나 주석 유지.
# multi-repo consumer (hub + impl repo 구조) 는 아래 주석 해제 후 각 <REPLACE> 값 입력.
#
# 활성화 조건: codeforge.stories.repos[] 에 1+ entry 선언 시 자동 활성.
# 부재 시 기존 single-repo flat 모드 유지 (backward compat).
#
# codeforge:
#   stories:
#     hub:
#       # hub repo 의 story key 발급 패턴 (예: "{prefix}-{seq:03d}")
#       key_pattern: "<REPLACE — e.g. MCT-{seq:03d}>"
#       # hub story 저장 디렉터리 (default: docs/stories)
#       story_dir: "docs/stories"
#       # hub story 생성 시 사용할 템플릿 (default: hub-story.md)
#       template: "hub-story.md"
#     # impl repo story key 패턴 (hub 와 동일 prefix 공유 권장)
#     repo_key_pattern: "<REPLACE — e.g. MCT-{seq:03d}>"
#     counters:
#       # counter file 위치 (hub repo root, committed)
#       path: ".codeforge/counters.json"
#       # lock mechanism — 현재 'file' 만 지원 (POSIX fcntl / cross-platform filelock)
#       lock: "file"
#     repos:
#       # governance hub repo (role: governance)
#       - name: "<REPLACE — e.g. mctrader-hub>"
#         role: governance
#         github: "<REPLACE — e.g. mclayer/mctrader-hub>"
#         story_dir: "docs/stories"
#         creates_repo_stories: false
#
#       # implementation repo (role: implementation) — 필요한 만큼 반복
#       - name: "<REPLACE — e.g. mctrader-data>"
#         role: implementation
#         # 로컬 sibling checkout 절대 경로 (또는 ${HOME}/... 형식)
#         path: "<REPLACE — e.g. /Users/you/workspace/mctrader-data>"
#         github: "<REPLACE — e.g. mclayer/mctrader-data>"
#         story_dir: "docs/stories"
#         components:
#           - "<REPLACE — e.g. data>"
#         creates_repo_stories: true
#
#       - name: "<REPLACE — e.g. mctrader-engine>"
#         role: implementation
#         path: "<REPLACE — e.g. /Users/you/workspace/mctrader-engine>"
#         github: "<REPLACE — e.g. mclayer/mctrader-engine>"
#         story_dir: "docs/stories"
#         components:
#           - "<REPLACE — e.g. engine>"
#         creates_repo_stories: true

# 3-way version atomic pin (CFP-820 / ADR-063 Amendment 5 §결정 15)
# Consumer 가 이 블록을 선언하면 version-3way-atomic.yml workflow 가
# publisher(plugin.json) ↔ registry(marketplace.json) ↔ consumer(project.yaml) 3-way 버전 일치 검증.
# 블록 부재 = warning-first exit 0 (orthogonality invariant — pin 미선언 ≠ 버전 불일치).
# 선언 후 버전 불일치 = blocking exit 1 (ADR-063 Amendment 5 §결정 15 AC-1).
#
# codeforge:
#   version_pin:
#     # codeforge plugin 설치 버전과 byte-identical 이어야 함
#     version: "<REPLACE — e.g. 5.82.0>"

# Parallel Dispatch Protocol (CFP-609 / ADR-064 Amendment 1)
# SSOT: docs/inter-plugin-contracts/parallel-dispatch-protocol-v1.md (kind:registry)
# Consumer overlay default 영역. ADR-064 §결정 7 ratchet — evidence-gated symmetric ratchet (강화·약화 양방향 + 양방향 evidence 의무).
# 변경 시 ADR-058 §결정 5 sunset_justification 의무.
parallel_dispatch:
  # 1. pl_autonomous_parallel_authority — PL 의 자율 병렬 권한 default
  #    enum 3-value (registry §6.1):
  #      required — ADR-064 §결정 4 default parallel 준수 (강력 권장 default)
  #      optional — consumer 가 명시적 sequential fallback 활성 (확장 channel)
  #      disabled — broken-baseline 회피 advisory only (ratchet 차단 영역 — sunset_justification 의무)
  #    변경 금지 — consumer 축소 불허 (ADR-064 §결정 7 ratchet 강제)
  pl_autonomous_parallel_authority: required

  # 2. plan_dag_hint_required — Orchestrator spawn prompt 에 DAG hint 박제 의무 여부
  #    true (default) = §3.0.14 의무 4 항목 prompt 박제 (ADR-064 §결정 4 강제)
  #    false (확장 영역) = consumer 명시적 opt-out (별 hotfix-bypass label 의무)
  plan_dag_hint_required: true

  # 3. dispatch_prompt_validation — `parallel-dispatch-prompt-check` lint enforcement level
  #    'warn' (default) = ADR-060 warning tier (continue-on-error: true)
  #    'block' (확장 영역) = consumer 자체 blocking enforcement (별 carrier CFP 의무)
  dispatch_prompt_validation: warn

  # 4. wall_clock_measurement — PMOAgent retro 에 wall-clock 기록 의무
  #    true (default) = Story 단위 timestamp delta 기록 (MCT-160 sunset gate 측정 carrier)
  wall_clock_measurement: true
