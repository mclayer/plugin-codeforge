# consumer-scripts.manifest — paths relative to plugin root.
# CFP-97 — these scripts must be copied to consumer projects alongside
# templates/github-workflows/ files, since consumer-distributable workflows
# may invoke them at CI runtime.
#
# Format (CFP-109 schema extension): one entry per line.
#   <script-path>[:<dependent-workflow-path>]
#     <script-path>: plugin-root-relative path to script (REQUIRED).
#     <dependent-workflow-path>: optional. plugin-root-relative path to the
#         workflow yml that invokes this script. Used by SessionStart hook
#         Check 4 to suppress the missing-script WARN when the workflow itself
#         is in workflow_distribution.missing_workflows (degraded consumers).
#
# Lines starting with '#' or empty are skipped.
# Lint: scripts/check-consumer-scripts-manifest.sh validates each entry
# (path traversal reject + file existence + executable bit + workflow constraint).
#
# When adding a new consumer-distributable workflow that invokes a script,
# also append the script's plugin-root-relative path here. If the workflow is
# in templates/github-workflows/, append `:templates/github-workflows/<name>.yml`
# to enable degraded-mode suppression.

scripts/check-story-section-schema.sh:templates/github-workflows/story-section-schema.yml
scripts/bootstrap-consumer.sh
scripts/check-debut-readiness.sh
scripts/check-lane-evidence.sh:templates/github-workflows/lane-evidence-check.yml
scripts/check-lint.sh
overlay/hooks/pre-push.sh.example

# CFP-136 / ADR-040 — worktree convention scripts (SessionStart hook + manual invocation).
# Source: templates/scripts/worktree-*.sh (plugin-relative).
# Consumer install path: ${CLAUDE_PROJECT_DIR}/templates/scripts/worktree-*.sh
#   (plugin-root-relative verbatim mirror per scripts/bootstrap-consumer.sh:335
#    `local target="$script_path"` — Stage 7 mirrors manifest entry 1:1, no `.claude/scripts/` rewrite).
templates/scripts/worktree-create.sh
templates/scripts/worktree-merge.sh
templates/scripts/worktree-prune.sh
templates/scripts/check-worktree-stale.sh
templates/scripts/worktree-path-util.sh

# CFP-744 Wave 2 Story-4 (#752 AC-10) — consumer 자기 repo 7-plugin atomic
# upgrade canonical flow 배포. Story-3 (CFP-743) per-plugin upgrade CLI +
# path 정규화 헬퍼 + Story-4 per-family transaction shell. workflow-invoked
# 아님 (CLI ad-hoc 단발) = dependent-workflow 미부착. bootstrap-consumer.sh
# Stage 7 가 consumer repo scripts/ 에 1:1 mirror → consumer 가 자기 repo 에서
# `--repo <consumer-repo-root>` 로 canonical upgrade flow 접근 (AC-11 §2g.2).
scripts/codeforge-upgrade.sh
scripts/codeforge-upgrade.ps1
scripts/lib/path_normalize.py
scripts/atomic-upgrade-7-plugins.sh
