{
  "_schema_version": "1.0",
  "_description": "codeforge enterprise-level ruleset skeleton (CFP-140 / ADR-162). Cascades to all org repos. Replace ENTERPRISE_SLUG_PLACEHOLDER before applying.",
  "_enterprise": "ENTERPRISE_SLUG_PLACEHOLDER",
  "name": "codeforge-enterprise-default",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/main"],
      "exclude": []
    }
  },
  "rules": [
    { "type": "deletion" },
    {
      "type": "required_pull_request",
      "parameters": {
        "required_approving_review_count": 1,
        "require_code_owner_review": false,
        "dismiss_stale_reviews_on_push": true,
        "require_last_push_approval": false
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "required_status_checks": [
          { "context": "phase-gate-mergeable" },
          { "context": "fix-ledger-sync" }
        ],
        "strict_required_status_checks_policy": false
      }
    }
  ],
  "bypass_actors": []
}
