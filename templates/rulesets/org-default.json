{
  "_schema_version": "1.0",
  "_description": "codeforge org-level ruleset skeleton (CFP-140 / ADR-048). Targets repos with criticality=high Custom Property. Replace placeholder values before applying.",
  "name": "codeforge-org-default",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/main"],
      "exclude": []
    },
    "repository_property": {
      "include": [
        {
          "name": "criticality",
          "source": "custom",
          "property_values": ["high"]
        }
      ],
      "exclude": []
    }
  },
  "rules": [
    { "type": "required_signatures" },
    { "type": "non_fast_forward" }
  ],
  "bypass_actors": []
}
