#!/usr/bin/env bash
# CFP-428 — pre-checkout hook (warning tier opt-in).
# Block: main working tree 에서 cfp-NNN checkout (worktree-first 정책 정합).
# carrier: ADR-040 Amendment 3 §결정 7.A action: worktree-first-pre-checkout
#
# 환경 변수:
#   BYPASS_WORKTREE_FIRST (선택, 1 = skip)
#     ADR-040 Amendment 3 §결정 7.E — `BYPASS_WORKTREE_GC` 와 disjoint scope.
#
# 인자 (git platform inherent, Pro Git book §8.3):
#   $1 — prev_HEAD SHA
#   $2 — next_HEAD SHA
#   $3 — branch_flag (1 = branch checkout, 0 = file checkout)
#
# Edge case (bare repo / detached worktree / submodule) — change-plan §3.1 결정 4:
#   - bare repo = working tree 부재 → hook trigger 0 (자연 OOS)
#   - detached worktree = git_dir != common_dir → Layer 5 분기 자동 short-circuit
#   - submodule = git_dir != common_dir → Layer 5 분기 자동 short-circuit (consumer 별도 carrier)

set -euo pipefail

if [[ "${BYPASS_WORKTREE_FIRST:-}" == "1" ]]; then exit 0; fi

prev_head="${1:-}"
next_head="${2:-}"
branch_checkout="${3:-}"

# Only act on branch checkouts (not file checkouts) — pre-checkout hook 3rd arg = 1 (branch) / 0 (file)
[[ "$branch_checkout" == "1" ]] || exit 0

# Detect if current working tree is main (vs worktree) — Researcher Unknown 2 회피
git_dir="$(git rev-parse --git-dir 2>/dev/null || echo "")"
common_dir="$(git rev-parse --git-common-dir 2>/dev/null || echo "")"
[[ -n "$git_dir" && "$git_dir" == "$common_dir" ]] || exit 0  # worktree 내부 또는 git 외부 = allow

next_branch="$(git rev-parse --abbrev-ref "$next_head" 2>/dev/null || echo "")"
if [[ "$next_branch" =~ ^cfp-[0-9]+ ]]; then
  echo "[pre-checkout] WARN: main working tree 에서 $next_branch checkout 시도. ADR-040 + playbook §3.0.11 worktree-first 정책 위반. 권장: bash templates/scripts/worktree-create.sh $next_branch origin/main" >&2
  # warning tier — allow (no exit 1)
fi

exit 0
